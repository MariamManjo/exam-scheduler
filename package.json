{
  "name": "exam-scheduler",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev": "vercel dev",
    "build": "npm run typecheck:api && npm run build:api && npm run verify:api && npm run build --prefix frontend",
    "build:api": "node scripts/build-api.mjs",
    "typecheck:api": "tsc -p server/tsconfig.json --noEmit",
    "verify:api": "node scripts/verify-api.mjs",
    "lint": "npm run lint --prefix frontend"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "openai": "^6.44.0"
  },
  "devDependencies": {
    "@types/node": "^24.12.3",
    "esbuild": "^0.25.0",
    "typescript": "~6.0.2",
    "vercel": "^41.7.0"
  }
}
